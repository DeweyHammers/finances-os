generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model AppSettings {
  id                        String  @id @default("global")
  paymentCycle              String  @default("BI_WEEKLY") // WEEKLY, BI_WEEKLY, MONTHLY
  eddActive                 Boolean @default(true)
  eddRemainingBalance       Float   @default(7200.00) 
  baseEddWeeklyAmount       Float   @default(450.00)
  
  w2Active                  Boolean @default(false)
  w2Amount                  Float   @default(0.00)
  
  upworkActive              Boolean @default(true)
  upworkTaxProvisionPercent Float   @default(0.25)
  upworkExpensesHoldActive  Boolean @default(false)
  upworkExpensesHoldAmount  Float   @default(0.00)
  upworkMinWithdrawalAmount Float   @default(0.00)
  wifeMonthlyAmount         Float   @default(0.00)
}

model Earning {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  description String?
  isWithdrawn Boolean  @default(false)
}

model Withdrawal {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  description String?
}

model DeductibleExpense {
  id          String   @id @default(cuid())
  amount      Float
  date        DateTime @default(now())
  description String?
}

model EddPayment {
  id        String   @id @default(cuid())
  amount    Float
  date      DateTime @default(now())
}

model Client {
  id        String    @id @default(cuid())
  name      String
  contracts Contract[]
}

model Contract {
  id            String   @id @default(cuid())
  name          String
  status        String   @default("ACTIVE") // ACTIVE, COMPLETED, ON_HOLD
  type          String   @default("HOURLY") // HOURLY, FIXED
  grossRate     Float    @default(0.00)
  netRate       Float    @default(0.00)
  feePercent    Float    @default(10.0) // Percentage UpWork takes (e.g. 10.0 for 10%)
  weeklyHours   Int      @default(0)
  startDate     DateTime @default(now())
  endDate       DateTime?
  completedDate DateTime?
  
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id])
  entries       ContractEntry[]
}

model ContractEntry {
  id         String   @id @default(cuid())
  date       DateTime @default(now())
  grossPay   Float
  netPay     Float
  hours      Float    @default(0.0)
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model Bill {
  id              String   @id @default(cuid())
  name            String
  amount          Float
  dueDate         Int      @default(1)
  withdrawalCycle String   @default("Q1") // Q1, Q2, Q3, Q4, MONTH
  isAutoPay       Boolean  @default(true)
}

model Personal {
  id              String   @id @default(cuid())
  name            String
  amount          Float
  dueDate         Int      @default(1)
  withdrawalCycle String   @default("Q1")
}

model YearlyCost {
  id     String @id @default(cuid())
  name   String
  amount Float
  month  Int    // 1-12
  day    Int    @default(1)
}

model JobReported {
  id           String   @id @default(cuid())
  employerName String
  date         DateTime @default(now())
}

model Account {
  id           String               @id @default(cuid())
  name         String
  notes        String?
  closed       Boolean              @default(false)
  sortOrder    Int                  @default(0)
  transactions AccountTransaction[]
}

model AccountTransaction {
  id             String              @id @default(cuid())
  accountId      String
  account        Account             @relation(fields: [accountId], references: [id], onDelete: Cascade)
  date           DateTime            @default(now())
  payeeId        String?
  payee          Payee?              @relation(fields: [payeeId], references: [id], onDelete: SetNull)
  categoryItemId String?
  categoryItem   BudgetCategoryItem? @relation(fields: [categoryItemId], references: [id], onDelete: SetNull)
  categoryName   String?
  memo           String?
  inflowCents    Int                 @default(0)
  outflowCents   Int                 @default(0)
  isAdjustment   Boolean             @default(false)
  cleared        Boolean             @default(true)
}

model Payee {
  id           String               @id @default(cuid())
  name         String               @unique
  transactions AccountTransaction[]
}

model BudgetCategoryGroup {
  id        String               @id @default(cuid())
  name      String
  sortOrder Int                  @default(0)
  items     BudgetCategoryItem[]
}

model BudgetCategoryItem {
  id                 String               @id @default(cuid())
  groupId            String
  group              BudgetCategoryGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name               String
  sortOrder          Int                  @default(0)
  sourceType         String               // "BILL" | "PERSONAL_NAME" | "CUSTOM"
  sourceBillId       String?
  sourcePersonalName String?
  customAmountCents  Int?
  customCycle        String?              // Q1-Q4 or null
  monthAssignments   BudgetMonth[]
  transactions       AccountTransaction[]
}

model BudgetMonth {
  id             String             @id @default(cuid())
  month          DateTime
  categoryItemId String
  categoryItem   BudgetCategoryItem @relation(fields: [categoryItemId], references: [id], onDelete: Cascade)
  assignedCents  Int                @default(0)

  @@unique([month, categoryItemId])
}